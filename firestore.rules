rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. GLOBAL SAFETY NET: Default to total deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. GLOBAL HELPERS
    function isSignedIn() { return request.auth != null; }

    // Admin check via hardcoded email — simple and reliable for single-admin apps.
    // To add more admins in the future, add their emails here.
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'heczaroficial@gmail.com' ||
        request.auth.token.email == 'HeczarOficial@gmail.com'
      );
    }

    function isOwner(userId) { return (isSignedIn() && request.auth.uid == userId) || isAdmin(); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 4. USER PROFILES
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow write: if isOwner(userId);
    }

    // 5. PROJECTS
    match /projects/{projectId} {
      allow get: if isOwner(existing().ownerId);
      allow list: if (isSignedIn() && resource.data.ownerId == request.auth.uid) || isAdmin();
      allow create: if isOwner(incoming().ownerId) && isValidProject(incoming());
      allow update: if isOwner(existing().ownerId) && 
                      incoming().ownerId == existing().ownerId &&
                      isValidProject(incoming());
      allow delete: if isOwner(existing().ownerId);

      function isValidProject(data) {
        return data.name is string && data.name.size() <= 100 &&
               data.description is string && data.description.size() <= 2000 &&
               data.methodology in ['SPE', 'DE', 'Custom'];
      }
    }

    // 6. ASSETS (Legacy - for backward compatibility)
    match /assets/{assetId} {
      allow get: if isSignedIn() && (get(/databases/$(database)/documents/projects/$(existing().projectId)).data.ownerId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && 
                      (get(/databases/$(database)/documents/projects/$(incoming().projectId)).data.ownerId == request.auth.uid || isAdmin()) &&
                      isValidAsset(incoming());
      allow delete: if isSignedIn() && (get(/databases/$(database)/documents/projects/$(existing().projectId)).data.ownerId == request.auth.uid || isAdmin());

      function isValidAsset(data) {
        return data.type in ['infographic', 'flyer', 'photo', 'social_post'] &&
               data.imageUrl is string && data.imageUrl.size() <= 2000 &&
               data.projectId is string;
      }
    }

    // 7. SAVED ASSETS (Gallery)
    match /saved_assets/{assetId} {
      allow get: if isOwner(existing().ownerId);
      allow list: if (isSignedIn() && resource.data.ownerId == request.auth.uid) || isAdmin();
      allow create: if isOwner(incoming().ownerId) && isValidSavedAsset(incoming());
      allow delete: if isOwner(existing().ownerId);

      function isValidSavedAsset(data) {
        return data.imageUrl is string &&
               data.brandName is string && data.brandName.size() <= 100 &&
               data.strategy is string && data.strategy.size() <= 10000 &&
               data.format is string && data.format.size() <= 100 &&
               data.style is string && data.style.size() <= 100 &&
               data.ownerId == request.auth.uid;
      }
    }

    // 8. PUBLICATIONS (Calendar / Content Ready)
    match /publications/{pubId} {
      allow get, delete: if isOwner(existing().ownerId);
      allow list: if (isSignedIn() && resource.data.ownerId == request.auth.uid) || isAdmin();
      allow create: if isOwner(incoming().ownerId) && isValidPublication(incoming());
      allow update: if isOwner(existing().ownerId) && incoming().ownerId == existing().ownerId;

      function isValidPublication(data) {
        return data.ownerId is string &&
               (data.title == null || (data.title is string && data.title.size() <= 200)) &&
               (data.content == null || (data.content is string && data.content.size() <= 50000));
      }
    }

    // 9. ADVISORIES (Admin Announcements)
    match /advisories/{advisoryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin(); // Only admins can create/update advisories
    }

    // 10. FUTURA COMERCIAL DOCUMENTS
    match /futura_comercial_docs/{docId} {
      allow read: if isOwner(resource.data.ownerId);
      allow create: if isOwner(incoming().ownerId);
      allow update, delete: if isOwner(existing().ownerId);
    }
  }
}
